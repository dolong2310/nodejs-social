  "scripts": {
    "dev": "nodemon --env=development",
    "dev:staging": "nodemon --env=staging",
    "dev:prod": "nodemon --env=production",
    "build": "tsc --incremental --tsBuildInfoFile .tsbuildinfo && tsc-alias",
    "build:clean": "rimraf ./dist .tsbuildinfo && tsc --incremental --tsBuildInfoFile .tsbuildinfo && tsc-alias",
    "start:dev": "node dist/index.js --env=development",
    "start:staging": "node dist/index.js --env=staging",
    "start:prod": "node dist/index.js --env=production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "test": "node --import ./tests/setup/register-argv.mjs ./node_modules/vitest/vitest.mjs run",
    "seed:create-admin-user:mongo": "tsx --tsconfig tsconfig.json src/infrastructure/persistence/seed/mongo/create-admin-user.ts --env=development",
    "seed:permissions:mongo": "tsx --tsconfig tsconfig.json src/infrastructure/persistence/seed/mongo/permissions.ts --env=development",
    "seed:fake-data:mongo": "tsx --tsconfig tsconfig.json src/infrastructure/persistence/seed/mongo/fake-data.ts --env=development",
    "seed:create-admin-user:postgres": "tsx --tsconfig tsconfig.json src/infrastructure/persistence/seed/postgres/create-admin-user.ts --env=development",
    "seed:permissions:postgres": "tsx --tsconfig tsconfig.json src/infrastructure/persistence/seed/postgres/permissions.ts --env=development",
    "seed:fake-data:postgres": "tsx --tsconfig tsconfig.json src/infrastructure/persistence/seed/postgres/fake-data.ts --env=development"
  },
