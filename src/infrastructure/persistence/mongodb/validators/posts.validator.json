{
  "$jsonSchema": {
    "title": "posts — aligned with modules/post/infrastructure/persistence/mongo/post.model (Valibot postSchema)",
    "bsonType": "object",
    "required": [
      "_id",
      "userId",
      "type",
      "audience",
      "allowStrangerComments",
      "content",
      "parentId",
      "hashtags",
      "mentions",
      "media"
    ],
    "properties": {
      "_id": {
        "bsonType": "string",
        "minLength": 36,
        "maxLength": 128
      },
      "userId": {
        "bsonType": "string",
        "minLength": 36,
        "maxLength": 128
      },
      "type": {
        "bsonType": "string",
        "enum": ["post", "repost", "comment", "quote"],
        "description": "EnumPostType"
      },
      "audience": {
        "bsonType": "string",
        "enum": ["public", "friends-only", "only-me"],
        "description": "EnumPostAudience"
      },
      "allowStrangerComments": { "bsonType": "bool" },
      "content": { "bsonType": "string" },
      "parentId": {
        "anyOf": [
          { "bsonType": "null" },
          {
            "bsonType": "string",
            "minLength": 36,
            "maxLength": 128
          }
        ]
      },
      "hashtags": {
        "bsonType": "array",
        "items": {
          "bsonType": "string",
          "minLength": 36,
          "maxLength": 128,
          "description": "Hashtag document id"
        }
      },
      "mentions": {
        "bsonType": "array",
        "items": {
          "bsonType": "string",
          "minLength": 36,
          "maxLength": 128,
          "description": "Mentioned user id"
        }
      },
      "media": {
        "bsonType": "array",
        "items": {
          "bsonType": "object",
          "required": ["url", "type"],
          "additionalProperties": false,
          "properties": {
            "url": {
              "bsonType": "string",
              "description": "IMedia.url (absolute http(s))"
            },
            "type": {
              "bsonType": "string",
              "enum": ["image", "video", "video-stream"],
              "description": "EnumMediaType"
            }
          }
        }
      },
      "guestViews": {
        "bsonType": ["int", "long", "double"],
        "minimum": 0
      },
      "userViews": {
        "bsonType": ["int", "long", "double"],
        "minimum": 0
      },
      "createdAt": { "bsonType": "date" },
      "updatedAt": { "bsonType": "date" }
    },
    "additionalProperties": false
  }
}
