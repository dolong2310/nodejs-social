{
  "$jsonSchema": {
    "title": "posts — aligned with modules/post/infrastructure/persistence/mongo/post.model (Valibot postSchema)",
    "bsonType": "object",
    "required": [
      "_id",
      "userId",
      "type",
      "audience",
      "allowStrangerComments",
      "content",
      "parentId"
    ],
    "properties": {
      "_id": {
        "bsonType": "string",
        "minLength": 36,
        "maxLength": 128
      },
      "userId": {
        "bsonType": "string",
        "minLength": 36,
        "maxLength": 128
      },
      "type": {
        "bsonType": "string",
        "enum": ["post", "repost", "comment", "quote"],
        "description": "EPostType"
      },
      "audience": {
        "bsonType": "string",
        "enum": ["public", "friends-only", "only-me"],
        "description": "EPostAudience"
      },
      "allowStrangerComments": { "bsonType": "bool" },
      "content": { "bsonType": "string" },
      "parentId": {
        "anyOf": [
          { "bsonType": "null" },
          {
            "bsonType": "string",
            "minLength": 36,
            "maxLength": 128
          }
        ]
      },
      "createdAt": { "bsonType": "date" },
      "updatedAt": { "bsonType": "date" }
    },
    "additionalProperties": false
  }
}
