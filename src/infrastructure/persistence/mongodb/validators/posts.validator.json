{
  "$jsonSchema": {
    "title": "posts object validation (aligned with PostEntity / IPost)",
    "bsonType": "object",
    "required": [
      "_id",
      "userId",
      "type",
      "audience",
      "allowStrangerComments",
      "content",
      "parentId",
      "hashtags",
      "mentions",
      "media",
      "guestViews",
      "userViews",
      "createdAt",
      "updatedAt"
    ],
    "properties": {
      "_id": {
        "bsonType": "objectId",
        "description": "_id must be an ObjectId"
      },
      "userId": {
        "bsonType": "objectId",
        "description": "author user id"
      },
      "type": {
        "bsonType": "string",
        "enum": ["post", "repost", "comment", "quote"],
        "description": "EPostType"
      },
      "audience": {
        "bsonType": "string",
        "enum": ["public", "friends-only", "only-me"],
        "description": "EPostAudience"
      },
      "allowStrangerComments": {
        "bsonType": "bool",
        "description": "If true, strangers who can see the post may comment/repost/quote when audience is public"
      },
      "content": {
        "bsonType": "string"
      },
      "parentId": {
        "bsonType": ["objectId", "null"]
      },
      "hashtags": {
        "bsonType": "array",
        "uniqueItems": true,
        "items": { "bsonType": "objectId" }
      },
      "mentions": {
        "bsonType": "array",
        "uniqueItems": true,
        "items": { "bsonType": "objectId" }
      },
      "media": {
        "bsonType": "array",
        "uniqueItems": true,
        "items": {
          "bsonType": "object",
          "required": ["url", "type"],
          "additionalProperties": false,
          "properties": {
            "url": {
              "bsonType": "string",
              "pattern": "^https?://.*",
              "description": "IMedia.url"
            },
            "type": {
              "bsonType": "string",
              "enum": ["image", "video", "video-hls"],
              "description": "EMediaType"
            }
          }
        }
      },
      "guestViews": {
        "bsonType": ["int", "long", "double"],
        "minimum": 0,
        "description": "Node driver may store JS numbers as double; int/long match explicit types"
      },
      "userViews": {
        "bsonType": ["int", "long", "double"],
        "minimum": 0
      },
      "createdAt": {
        "bsonType": "date"
      },
      "updatedAt": {
        "bsonType": "date"
      }
    },
    "additionalProperties": false
  }
}
